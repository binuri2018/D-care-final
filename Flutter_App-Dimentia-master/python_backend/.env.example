PORT=4000
# Replace with YOUR Atlas host (from Atlas → Connect → Drivers). Do not leave cluster.example.mongodb.net.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/ticketdb?appName=Cluster0
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
PYTHON_BIN=python
MRI_TFLITE_PATH=../MRI_Data_set/mri_mobilenetv2_fp16.tflite
CLINICAL_JOBLIB_PATH=../Clinical Model/clinical_xgb_model.joblib
RISK_MRI_WEIGHT=0.6
RISK_CLINICAL_WEIGHT=0.4
HEARTBEAT_STALE_MINUTES=10
OLLAMA_BASE_URL=https://api.openai.com/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-4o-mini
REPORTS_DIR=data/reports
