# Copy to backend/.env and adjust. Restart uvicorn after changes.

# --- Dementia Guardian (auth, pairing, alerts, …) — required for /api/auth/* ---
# Atlas example:
# MONGO_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/ticketdb?retryWrites=true&w=majority
# Local MongoDB (install + run mongod), same as below:
# MONGO_URI=mongodb://127.0.0.1:27017

# Convenience: if MONGO_URI is unset, use local mongod on 27017 (dev only)
# GUARDIAN_USE_LOCAL_MONGO_DEV=1

# Optional: disable guardian subsystem entirely
# ENABLE_GUARDIAN_API=0

# Optional: extra CORS origins (comma-separated) for web dev on other hosts/ports
# CORS_ALLOW_ORIGINS=http://192.168.1.10:3000

# Optional: Python executable for clinical/MRI inference subprocesses (default: same interpreter as the API)
# PYTHON_BIN=C:\Users\You\AppData\Local\Programs\Python\Python310\python.exe
